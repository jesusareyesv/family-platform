# ============================================================
#  Family Platform API — Environment Variables
#  cp .env.example .env  and fill in values
# ============================================================

# ── Database ─────────────────────────────────────────────
# Local dev (SQLite, no setup needed):
DATABASE_URL=sqlite:///./family.db
# Production (Supabase connection string):
# DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────
# "local" → SQLite + local JWTs (no email confirmation)
# "supabase" → delegates auth to Supabase
AUTH_MODE=local

# Secret for signing JWTs in local mode.
# In production set this to your Supabase JWT secret (Settings → API → JWT Secret).
JWT_SECRET=dev-secret-change-in-production

# ── Supabase (only needed when AUTH_MODE=supabase) ────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS_STR=http://localhost:3000
